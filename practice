.MODEL SMALL
.STACK 100H

.DATA
    ; Menu and Prompts
    MENU    DB 0DH, 0AH, "--- Arithmetic Menu ---", 0DH, 0AH, "1. Addition", 0DH, 0AH, "2. Subtraction", 0DH, 0AH, "3. Multiplication", 0DH, 0AH, "4. Division", 0DH, 0AH, "5. Exit", 0DH, 0AH, "Choose: $"
    PRMPT1  DB 0DH, 0AH, "Enter First Number (0-9): $"
    PRMPT2  DB 0DH, 0AH, "Enter Second Number (0-9): $"
    RE_MSG  DB 0DH, 0AH, "Result: $"
    ERR_DIV DB 0DH, 0AH, "Error: Division by zero$"
    CONT_MSG DB 0DH, 0AH, "Do you want to continue? (1/0): $"
    
    NUM1    DB ?
    NUM2    DB ?
    CHOICE  DB ?

.CODE
MAIN PROC
    MOV AX, @DATA
    MOV DS, AX

START_PROG:
    ; 1. Display Menu
    LEA DX, MENU
    MOV AH, 09H
    INT 21H

    ; Get Choice
    MOV AH, 01H
    INT 21H
    SUB AL, '0'
    MOV CHOICE, AL
    
    ; Check for Exit (Choice 5)
    CMP AL, 5
    JE EXIT_PROG

    ; 2. Ask for numbers
    LEA DX, PRMPT1
    MOV AH, 09H
    INT 21H
    MOV AH, 01H
    INT 21H
    SUB AL, '0'
    MOV NUM1, AL

    LEA DX, PRMPT2
    MOV AH, 09H
    INT 21H
    MOV AH, 01H
    INT 21H
    SUB AL, '0'
    MOV NUM2, AL

    ; 3. Branching based on selection
    MOV AL, CHOICE
    CMP AL, 1
    JE ADDITION
    CMP AL, 2
    JE SUBTRACTION
    CMP AL, 3
    JE MULTIPLICATION
    CMP AL, 4
    JE DIVISION
    JMP START_PROG ; Invalid choice retry

ADDITION:
    MOV AL, NUM1
    ADD AL, NUM2
    JMP DISPLAY_RESULT

SUBTRACTION:
    MOV AL, NUM1
    SUB AL, NUM2
    JMP DISPLAY_RESULT

MULTIPLICATION:
    MOV AL, NUM1
    MOV BL, NUM2
    MUL BL          ; Result in AL
    JMP DISPLAY_RESULT

DIVISION:
    CMP NUM2, 0     ; Handle div by zero
    JE DIV_ERROR
    MOV AL, NUM1
    MOV AH, 0
    MOV BL, NUM2
    DIV BL          ; Quotient in AL
    JMP DISPLAY_RESULT

DIV_ERROR:
    LEA DX, ERR_DIV
    MOV AH, 09H
    INT 21H
    JMP ASK_CONTINUE

DISPLAY_RESULT:
    ; Store calculation result temporarily
    MOV BL, AL
    LEA DX, RE_MSG
    MOV AH, 09H
    INT 21H

    ; Basic result display (Single digit assumed for simplicity per requirement)
    ; For 2-digit results (like 5+8=13), AAM can be used, but keeping it basic:
    MOV AL, BL
    ADD AL, '0'     ; Convert back to ASCII
    MOV DL, AL
    MOV AH, 02H
    INT 21H

ASK_CONTINUE:
    LEA DX, CONT_MSG
    MOV AH, 09H
    INT 21H
    
    MOV AH, 01H
    INT 21H
    CMP AL, '1'
    JE START_PROG

EXIT_PROG:
    MOV AH, 4CH
    INT 21H
MAIN ENDP
END MAIN
